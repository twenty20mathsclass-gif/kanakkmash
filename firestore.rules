
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        request.auth.token.email == 'kanakkmash@gmail.com'
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- User Profiles & Details ---

    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      match /attendance/{attendanceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /teacher_details/{detailsDoc} {
        allow read, write: if (isOwner(userId) && isRole('teacher')) || isAdmin();
      }

      match /promoter_details/{detailsDoc} {
        allow read, write: if (isOwner(userId) && isRole('promoter')) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId);
        allow create: if isRole('teacher') || isAdmin();
      }

      match /salaryPayments/{paymentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      match /referrals/{studentId} {
        allow read: if (isOwner(userId) && (isRole('teacher') || isRole('promoter'))) || isAdmin();
        allow create: if request.auth != null && request.auth.uid == studentId;
        allow update, delete: if isAdmin();
      }
      
      match /rewards/{rewardId} {
        allow read: if isOwner(userId) || isRole('promoter') || isAdmin();
        allow create: if request.auth != null;
        allow update, delete: if isAdmin();
      }
    }

    // --- Chat Room (WhatsApp Style) ---

    // Private 1-on-1 Chats
    match /chats/{chatId} {
      function isParticipant() {
        return request.auth != null && (request.auth.uid in chatId.split('_') || isAdmin());
      }

      allow read: if isParticipant();
      
      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant() && request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(); // Allow marking as read
        allow delete: if false;
      }
    }

    // Group Chats
    match /groups/{groupId} {
      function isMember() {
        return request.auth != null && (request.auth.uid in resource.data.members || isAdmin());
      }
      
      // Helper specifically for sub-collections where 'resource' isn't the group itself
      function isGroupMember(gId) {
        return request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(gId)).data.members || 
          isAdmin()
        );
      }

      allow read: if isMember();
      allow create: if isRole('teacher') || isAdmin();
      allow update: if isMember() || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isGroupMember(groupId);
      }
    }

    // --- Presence System ---
    
    match /status/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }

    // --- Educational Content & Scheduling ---

    match /courseModels/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow create: if isRole('teacher') || isAdmin();
      allow update, delete: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);

      match /attendees/{userId} {
        allow create: if isOwner(userId);
        allow get, list: if request.auth != null;
      }
    }

    match /exams/{examId} {
      allow get, list: if request.auth != null;
      allow create: if isRole('teacher') || isAdmin();
      allow read, update, delete: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);

      match /submissions/{userId} {
        allow create: if isOwner(userId);
        allow get, list: if request.auth != null;
        allow update: if isAdmin() || (isRole('teacher') && get(/databases/$(database)/documents/exams/$(examId)).data.teacherId == request.auth.uid);
      }
    }

    match /recordedClasses/{classId} {
      allow read: if request.auth != null;
      allow create: if isRole('teacher') || isAdmin();
      allow update, delete: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);
    }

    // --- Administrative Collections ---

    match /courseFees/{feeId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /cartContent/{docId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    match /courseCategories/{categoryId} { 
      allow read: if true; 
      allow write: if isAdmin() || isRole('teacher'); 
    }
    
    match /popularCourses/{popularId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    match /testimonials/{testimonialId} { 
      allow get, list: if true; 
      allow write: if isAdmin(); 
    }
    
    match /invoices/{invoiceId} { 
      allow create: if request.auth != null; 
      allow get: if isOwner(get(/databases/$(database)/documents/invoices/$(invoiceId)).data.studentId) || isAdmin(); 
      allow list: if isAdmin(); 
    }
    
    match /salaryInvoices/{invoiceId} { 
      allow get: if isOwner(get(/databases/$(database)/documents/salaryInvoices/$(invoiceId)).data.teacherId) || isAdmin(); 
      allow list, write: if isAdmin(); 
    }

    // --- Community & Blog ---

    match /blogPosts/{postId} { 
      allow get, list: if true; 
      allow create: if isRole('admin') || isRole('teacher'); 
      allow update: if request.auth != null && (isAdmin() || resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isAdmin() || (isRole('teacher') && resource.data.authorId == request.auth.uid);
      
      match /comments/{commentId} { 
        allow read, list: if true; 
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (isAdmin() || resource.data.authorId == request.auth.uid);
      }
    }
  }
}
