
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Safely check a user's role.
    function isRole(role) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) && get(userDocPath).data.role == role;
    }

    // A user is an admin if their user document has role == 'admin'.
    function isAdmin() {
      return isRole('admin');
    }

    // The requesting user is the owner of the data.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExamOwner(examId) {
      return get(/databases/$(database)/documents/exams/$(examId)).data.teacherId == request.auth.uid;
    }

    match /users/{userId} {
      // Any authenticated user can read public user profiles.
      allow read: if request.auth != null;
      
      // A user can create their own profile, and an admin can create any user profile.
      allow create: if isOwner(userId) || isAdmin();

      // Admins can update any profile. Users can only update their own.
      // A user cannot change their own role.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      
      // Admins can delete users. Users can delete their own account.
      allow delete: if isAdmin() || isOwner(userId);

      match /attendance/{attendanceId} {
        // A user can create/read/update/delete their own attendance records.
        allow read, write: if isOwner(userId);
      }
      
      match /teacher_details/{detailsDoc} {
        // Teacher can manage their own private details. Admin can manage any.
        allow read, write: if (isOwner(userId) && isRole('teacher')) || isAdmin();
      }
    }

    match /schedules/{scheduleId} {
      // Anyone logged in can see schedules
      allow list, get: if request.auth != null;

      // Only teachers or admins can create schedules. Teachers must be the owner.
      allow create: if (isRole('teacher') && request.resource.data.teacherId == request.auth.uid) || isRole('admin');

      // Only the teacher who owns the schedule or an admin can update/delete it
      allow update, delete: if (resource.data.teacherId == request.auth.uid) || isAdmin();

      match /attendees/{userId} {
        // Student can create their own attendance record for a schedule
        allow create: if isOwner(userId);
        // Teacher who owns the schedule, the student, or an admin can read attendance
        allow get, list: if get(/databases/$(database)/documents/schedules/$(scheduleId)).data.teacherId == request.auth.uid || isOwner(userId) || isAdmin();
        // No one can update or delete from here to preserve attendance record.
        allow update, delete: if false;
      }
    }

    match /exams/{examId} {
      // Any authenticated user can read an exam.
      allow get, list: if request.auth != null;
      // Teachers and admins can create exams. Teachers must own them.
      allow create: if (isRole('teacher') && request.resource.data.teacherId == request.auth.uid) || isAdmin();
      // Teacher who owns it or admin can manage.
      allow read, update, delete: if isExamOwner(examId) || isAdmin();

      match /submissions/{userId} {
        // A student can create their own submission.
        allow create: if isOwner(userId);
        // Student can read their own submission.
        // Teacher who owns the exam or admin can read any submission for that exam.
        allow get, list: if isOwner(userId) || isExamOwner(examId) || isAdmin();
        // Submissions cannot be updated or deleted.
        allow update, delete: if false;
      }
    }

    match /cartContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /courseCategories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() || isRole('teacher');
    }
    match /popularCourses/{popularId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
        allow read, write: if isAdmin();
    }

    match /salaryPayments/{paymentId} {
        // Admins can read/write any payment.
        allow get: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);
        // Teachers can list salary payments, but the client MUST filter by their teacherId.
        allow list: if isAdmin() || isRole('teacher');
        allow write: if isAdmin();
    }
    
    match /blogPosts/{postId} {
      allow get, list: if true;
      allow create: if isRole('admin') || isRole('teacher');
      allow update: if (isRole('teacher') && request.resource.data.authorId == request.auth.uid) || isAdmin();
      allow delete: if (isRole('teacher') && resource.data.authorId == request.auth.uid) || isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      // The chatId is a composite of two UIDs, sorted and joined by '_'
      // A user can read messages if their UID is in the chatId.
      allow read: if request.auth.uid in split(chatId, '_');
      
      // A user can create a message if they are a participant and the sender.
      allow create: if (request.auth.uid in split(chatId, '_')) && request.resource.data.senderId == request.auth.uid;
      
      // Messages are immutable.
      allow update, delete: if false;
    }
  }
}
