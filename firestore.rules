
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.token.email == 'kanakkmash@gmail.com');
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin() || isOwner(userId);

      match /attendance/{attendanceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /teacher_details/{detailsDoc} {
        allow read, write: if (isOwner(userId) && isRole('teacher')) || isAdmin();
      }

      match /promoter_details/{detailsDoc} {
        allow read, write: if (isOwner(userId) && isRole('promoter')) || isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId);
        allow create: if isRole('teacher') || isAdmin();
      }

      match /salaryPayments/{paymentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      match /referrals/{studentId} {
        allow read: if (isOwner(userId) && (isRole('teacher') || isRole('promoter'))) || isAdmin();
        allow create: if request.auth != null && request.auth.uid == studentId;
        allow update, delete: if isAdmin();
      }
      
      match /rewards/{rewardId} {
        allow read: if isOwner(userId) || isRole('promoter') || isAdmin();
        allow create: if request.auth != null;
        allow update, delete: if isAdmin();
      }
    }

    match /groups/{groupId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.members || isAdmin());
      allow create: if isRole('teacher') || isAdmin();
      allow update: if request.auth != null && (request.auth.uid in resource.data.members || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members || isAdmin());
        allow create: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members || isAdmin());
      }
    }

    match /chats/{chatId} {
      function isParticipant() {
        return request.auth != null && (request.auth.uid in chatId.split('_') || isAdmin());
      }

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant() && request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant();
        allow delete: if false;
      }
    }

    match /courseModels/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create: if (isRole('teacher')) || isAdmin();
      allow update, delete: if (resource.data.teacherId == request.auth.uid) || isAdmin();

      match /attendees/{userId} {
        allow create: if isOwner(userId);
        allow get, list: if request.auth != null;
      }
    }

    match /exams/{examId} {
      allow get, list: if request.auth != null;
      allow create: if isRole('teacher') || isAdmin();
      allow read, update, delete: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);

      match /submissions/{userId} {
        allow create: if isOwner(userId);
        allow get, list: if request.auth != null;
      }
    }

    match /courseFees/{feeId} {
      allow write: if isAdmin();
      allow read, list: if true;
    }

    match /recordedClasses/{classId} {
      allow read: if request.auth != null;
      allow create: if isRole('teacher') || isAdmin();
      allow update, delete: if isAdmin() || (isRole('teacher') && resource.data.teacherId == request.auth.uid);
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /status/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }
    
    match /cartContent/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /courseCategories/{categoryId} { allow read: if true; allow write: if isAdmin() || isRole('teacher'); }
    match /popularCourses/{popularId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{testimonialId} { allow get, list: if true; allow write: if isAdmin(); }
    match /invoices/{invoiceId} { allow create: if request.auth != null; allow get: if true; allow list: if isAdmin(); }
    match /salaryInvoices/{invoiceId} { allow write: if isAdmin(); allow get: if true; allow list: if isAdmin(); }
    match /blogPosts/{postId} { 
      allow get, list: if true; 
      allow create: if isRole('admin') || isRole('teacher'); 
      allow update: if request.auth != null;
      allow delete: if isAdmin() || (isRole('teacher') && resource.data.authorId == request.auth.uid);
      match /comments/{commentId} { allow read, list: if true; allow create, delete: if request.auth != null; }
    }
  }
}
