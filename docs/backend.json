
{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's unique ID." },
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["student", "teacher", "admin", "promoter"], "description": "The user's role." },
        "learningMode": { "type": "string", "enum": ["group", "one to one"], "description": "The student's preferred learning mode." },
        "teachingMode": { "type": "string", "enum": ["group", "one to one", "both"], "description": "The teacher's assigned teaching mode." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "URL of the user's avatar image." },
        "createdAt": { "type": "object", "description": "The date and time the user account was created." },
        "referredBy": { "type": "string", "description": "The UID of the user who referred this user." },
        "rewardPercentage": { "type": "number", "description": "The custom reward percentage for a promoter." },
        "assignedClasses": { "type": "array", "items": { "type": "string" }, "description": "The classes a teacher is assigned to." }
      },
      "required": ["id", "name", "email", "role"]
    },
    "chatGroup": {
      "title": "Chat Group",
      "description": "Represents a group chat room.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "admins": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "object" },
        "isGroup": { "type": "boolean" }
      },
      "required": ["name", "members", "admins", "createdBy", "createdAt", "isGroup"]
    },
    "chatMessage": {
      "title": "Chat Message",
      "description": "Represents a single message in a chat conversation.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the message." },
        "senderId": { "type": "string", "description": "The UID of the user who sent the message." },
        "timestamp": { "type": "object", "description": "The server timestamp when the message was sent." },
        "isRead": { "type": "boolean", "description": "Whether the message has been read by the recipient." }
      },
      "required": ["text", "senderId", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "Stores public user profile information."
    },
    "/groups/{groupId}": {
      "schema": { "$ref": "#/entities/chatGroup" },
      "description": "Stores group chat metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/chatMessage" },
      "description": "Stores individual chat messages."
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/chatMessage" },
      "description": "Stores group chat messages."
    }
  }
}
