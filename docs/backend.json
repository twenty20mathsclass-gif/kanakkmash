{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's unique ID." },
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"], "description": "The user's role." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "URL of the user's avatar image." },
        "createdAt": { "type": "object", "description": "The date and time the user account was created." }
      },
      "required": ["id", "name", "email", "role"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "A testimonial from a student.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string", "description": "The name of the student." },
        "quote": { "type": "string", "description": "The testimonial text." },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL of the student's image." },
        "videoUrl": { "type": "string", "format": "uri", "description": "Optional URL of a video testimonial." },
        "link": { "type": "string", "format": "uri", "description": "Optional link to a project or profile." },
        "createdAt": { "type": "object", "description": "The date and time the testimonial was created." }
      },
      "required": ["studentName", "quote", "imageUrl", "createdAt"]
    },
    "invoice": {
      "title": "Invoice",
      "description": "Represents a student invoice for fees or purchases.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The ID of the student this invoice belongs to." },
        "amount": { "type": "number", "description": "The total amount of the invoice." },
        "status": { "type": "string", "enum": ["paid", "unpaid", "overdue"], "description": "The payment status of the invoice." },
        "type": { "type": "string", "enum": ["fee", "cart"], "description": "The type of invoice." },
        "createdAt": { "type": "object", "description": "The date the invoice was created." },
        "dueDate": { "type": "object", "description": "The date the invoice is due." },
        "paidAt": { "type": "object", "description": "The date the invoice was paid." }
      },
      "required": ["studentId", "amount", "status", "type", "createdAt", "dueDate"]
    },
    "salaryPayment": {
      "title": "Salary Payment",
      "description": "Represents a salary payment made to a teacher.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string", "description": "The ID of the teacher receiving the payment." },
        "amount": { "type": "number", "description": "The amount paid." },
        "paymentDate": { "type": "object", "description": "The date the payment was made." },
        "periodStart": { "type": "object", "description": "The start date of the payment period." },
        "periodEnd": { "type": "object", "description": "The end date of the payment period." }
      },
      "required": ["teacherId", "amount", "paymentDate", "periodStart", "periodEnd"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "Stores user profile information."
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/testimonial" },
      "description": "Stores student testimonials."
    },
    "/schedules/{scheduleId}": {
        "schema": {},
        "description": "Stores class and exam schedules."
    },
    "/exams/{examId}": {
        "schema": {},
        "description": "Stores exam content."
    },
    "/cartContent/{docId}": {
        "schema": {},
        "description": "Stores content for the cart page."
    },
    "/courseCategories/{categoryId}": {
        "schema": {},
        "description": "Stores course categories for the cart page."
    },
     "/popularCourses/{popularId}": {
        "schema": {},
        "description": "Stores popular course mappings."
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/invoice" },
      "description": "Stores student invoices."
    },
    "/salaryPayments/{paymentId}": {
      "schema": { "$ref": "#/entities/salaryPayment" },
      "description": "Stores teacher salary payment records."
    }
  }
}
